/*
 * Nextflow Configuration File
 * Raichu + pyHICCUPS Pipeline
 */

// Manifest
manifest {
    name = 'microc-loops'
    author = 'Seqera AI'
    description = 'Hi-C loop detection pipeline using raichu normalization and pyHICCUPS'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '>=23.04.0'
}

// Default parameters
params {
    // Input/Output
    input = null
    outdir = 'results'
    
    // Resolution settings
    resolutions = '2000,5000,10000'
    
    // Tool-specific options
    raichu_options = ''
    pyhiccups_options = ''
    
    // Resource defaults
    max_memory = '16.GB'
    max_cpus = 8
    max_time = '24.h'
}

// Process configuration
process {
    // Default resources
    cpus = 2
    memory = 4.GB
    time = 4.h
    
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Process-specific settings
    withName: 'RAICHU_NORMALIZE' {
        cpus = 4
        memory = 8.GB
        time = 6.h
    }
    
    withName: 'PYHICCUPS_CALL_LOOPS' {
        cpus = 4
        memory = 8.GB
        time = 8.h
    }
    
    withName: 'COMBINE_LOOPS' {
        cpus = 1
        memory = 2.GB
        time = 1.h
    }
    
    withName: 'BEDPE_TO_ARC' {
        cpus = 1
        memory = 2.GB
        time = 1.h
    }
    
    withName: 'GENERATE_STATS' {
        cpus = 1
        memory = 2.GB
        time = 1.h
    }
}

// Execution profiles
profiles {
    standard {
        process.executor = 'local'
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
    
    conda {
        conda.enabled = true
    }
    
    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
        executor.queueSize = 50
    }
    
    aws {
        process.executor = 'awsbatch'
        process.queue = 'nextflow-queue'
        aws.region = 'us-east-1'
        aws.batch.cliPath = '/home/ec2-user/miniconda/bin/aws'
    }
    
    gcp {
        process.executor = 'google-batch'
        google.project = 'your-project-id'
        google.region = 'us-central1'
    }
    
    test {
        params.input = 'test_data/sample.cool'
        params.outdir = 'test_results'
        params.resolutions = '5000,10000'
    }
}

// Report configuration
report {
    enabled = true
    file = "${params.outdir}/reports/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.outdir}/reports/timeline.html"
}

trace {
    enabled = true
    file = "${params.outdir}/reports/trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/reports/pipeline_dag.svg"
}

// Cleanup
cleanup = false
